@startuml cas_utilisation
' Diagramme de cas d'utilisation — Yalta (itération sans IA)

left to right direction
skinparam actorStyle awesome

actor "Joueur humain" as Humain
actor "Joueur IA\n(itération suivante)" as IA

rectangle "Application Yalta" {
    usecase "Lancer une nouvelle partie" as UC1
    usecase "Sélectionner une pièce" as UC2
    usecase "Visualiser les coups légaux" as UC3
    usecase "Jouer un coup" as UC4
    usecase "Effectuer un roque" as UC5
    usecase "Promouvoir un pion" as UC6
    usecase "Effectuer une prise en passant" as UC7
    usecase "Être notifié d'un échec" as UC8
    usecase "Abandonner la partie" as UC9
    usecase "Consulter l'historique des coups" as UC10
}

Humain --> UC1
Humain --> UC2
Humain --> UC3
Humain --> UC4
Humain --> UC9
Humain --> UC10
Humain <-- UC8

IA ..> UC4 : (futur)

UC4 <.. UC5 : <<extend>>
UC4 <.. UC6 : <<extend>>
UC4 <.. UC7 : <<extend>>
UC2 <.. UC3 : <<include>>
UC4 ..> UC8 : <<include>>

@enduml
